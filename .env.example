# ── AI Job Agent — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is in .gitignore — NEVER commit it.

# Naukri login credentials (used by scraper.py and batch_apply.py)
NAUKRI_EMAIL=your_naukri_email@example.com
NAUKRI_PASSWORD=your_naukri_password_here

# Groq API key (LLM inference — free tier available at console.groq.com)
# The Setup Wizard also saves this to config.json; this .env entry is a fallback.
GROQ_API_KEY=gsk_your_groq_api_key_here

# Dashboard API token — protects all POST endpoints from unauthenticated access.
# If omitted, a random token is auto-generated at server startup and printed in the log.
# Copy the printed token here to make it permanent across restarts.
AGENT_API_TOKEN=your_random_token_here
